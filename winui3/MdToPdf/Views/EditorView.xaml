<UserControl
    x:Class="MdToPdf.Views.EditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="16" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding WordCountText}" HorizontalAlignment="Right" Opacity="0.7" />

        <TextBox Grid.Row="1"
                 Text="{Binding PastedMarkdown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 FontFamily="Cascadia Mono, Consolas, monospace"
                 PlaceholderText="Paste or type Markdown here..."
                 VerticalContentAlignment="Top"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
    </Grid>
</UserControl>
