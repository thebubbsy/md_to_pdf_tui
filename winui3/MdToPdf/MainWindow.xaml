<Window
    x:Class="MdToPdf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MdToPdf.Views">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="40">
            <TextBlock Text="MDPDFM Pro" VerticalAlignment="Center" Margin="16,0,0,0" />
        </Grid>

        <TextBlock Grid.Row="1" Text="Minimal test window" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Window>
